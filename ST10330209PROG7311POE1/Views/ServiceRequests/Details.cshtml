@model ST10330209PROG7311POE1.Models.ServiceRequest
@{
    ViewData["Title"] = "Service Request Details";
}
<h2>Service Request Details</h2>
<dl class="row">
    <dt class="col-sm-2">Contract</dt>
    <dd class="col-sm-10">@Model.Contract?.Client?.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">Cost (USD)</dt>
    <dd class="col-sm-10">@Model.CostInUSD</dd>

    <dt class="col-sm-2">Cost (ZAR)</dt>
    <dd class="col-sm-10">@Model.CostInZAR</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
</dl>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>