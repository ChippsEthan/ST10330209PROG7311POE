@model IEnumerable<ST10330209PROG7311POE1.Models.Client>
@{
    ViewData["Title"] = "Clients";
}
<h2>Clients</h2>
<p><a asp-action="Create" class="btn btn-primary">Add Client</a></p>
<table class="table">
    <thead>
        <tr><th>Name</th><th>Contact</th><th>Region</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.ContactDetails</td>
                <td>@client.Region</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@client.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@client.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@client.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>