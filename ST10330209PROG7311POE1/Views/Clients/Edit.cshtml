@model ST10330209PROG7311POE1.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}
<h2>Edit Client</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-3"><label asp-for="ContactDetails" class="form-label"></label><input asp-for="ContactDetails" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Region" class="form-label"></label><input asp-for="Region" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>