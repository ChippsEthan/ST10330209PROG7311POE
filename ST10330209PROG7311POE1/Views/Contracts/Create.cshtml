@model ST10330209PROG7311POE1.Models.Contract
@{
    ViewData["Title"] = "Create Contract";
}
<h2>Create Contract</h2>
<form asp-action="Create" enctype="multipart/form-data" method="post">
    <div class="mb-3"><label>Client</label><select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select></div>
    <div class="mb-3"><label>Start Date</label><input asp-for="StartDate" type="date" class="form-control" /></div>
    <div class="mb-3"><label>End Date</label><input asp-for="EndDate" type="date" class="form-control" /></div>
    <div class="mb-3"><label>Status</label><select asp-for="Status" class="form-select"><option>Draft</option><option>Active</option><option>Expired</option><option>OnHold</option></select></div>
    <div class="mb-3"><label>Service Level</label><input asp-for="ServiceLevel" class="form-control" /></div>
    <div class="mb-3"><label>PDF Agreement</label><input type="file" name="pdfFile" accept=".pdf" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>