@model ST10330209PROG7311POE1.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}
<h2>Delete Contract</h2>
<p>Are you sure you want to delete this contract?</p>
<div>
    <dl class="row">
        <dt class="col-sm-2">Client</dt>
        <dd class="col-sm-10">@Model.Client?.Name</dd>
        <dt class="col-sm-2">Start Date</dt>
        <dd class="col-sm-10">@Model.StartDate.ToShortDateString()</dd>
        <dt class="col-sm-2">End Date</dt>
        <dd class="col-sm-10">@Model.EndDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
        <dt class="col-sm-2">PDF</dt>
        <dd class="col-sm-10">@if(!string.IsNullOrEmpty(Model.SignedAgreementPath)){
        <a href="@Model.SignedAgreementPath" target="_blank">View PDF</a>
                }
</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>