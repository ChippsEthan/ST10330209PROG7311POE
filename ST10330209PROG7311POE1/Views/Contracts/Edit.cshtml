@model ST10330209PROG7311POE1.Models.Contract
@{
    ViewData["Title"] = "Edit Contract";
}
<h2>Edit Contract</h2>
<form asp-action="Edit" enctype="multipart/form-data" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label>Client</label>
        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label>Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label>End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Status</label>
        <select name="newStatus" class="form-select">
            <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
            <option value="Active" selected="@(Model.Status == "Active")">Active</option>
            <option value="Expired" selected="@(Model.Status == "Expired")">Expired</option>
            <option value="OnHold" selected="@(Model.Status == "OnHold")">OnHold</option>
        </select>
    </div>
    <div class="mb-3">
        <label>Service Level</label>
        <input asp-for="ServiceLevel" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Replace PDF (optional, PDF only)</label>
        <input type="file" name="pdfFile" accept=".pdf" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>